# =============================================================================
# AnyMinute Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit the actual .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# MongoDB connection string
MONGO_URL=mongodb://localhost:27017

# Database name (change for production)
DB_NAME=anyminute_db

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Use specific domains in production, not "*"
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# AUTHENTICATION - JWT
# -----------------------------------------------------------------------------
# Secret key for AnyMinute JWT tokens (generate a strong random string)
# Example: openssl rand -hex 32
AM_JWT_SECRET=change-this-to-a-random-32-character-string

# Secret key for Payroll Canada JWT tokens
JWT_SECRET=change-this-to-another-random-32-character-string

# JWT token expiration in hours
JWT_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# STRIPE PAYMENT INTEGRATION
# -----------------------------------------------------------------------------
# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
# Use sk_test_ and pk_test_ for development
# Use sk_live_ and pk_live_ for production
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# Stripe webhook signing secret (get from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe mode: "test" or "live"
STRIPE_MODE=test

# -----------------------------------------------------------------------------
# EMAIL SERVICE
# -----------------------------------------------------------------------------
# Set to "true" to enable real email sending
# Set to "false" to use mock/console logging mode
EMAILS_ENABLED=false

# SMTP server configuration (example: SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key-here
SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# ANYMINUTE <-> PAYROLL INTEGRATION
# -----------------------------------------------------------------------------
# Base URL for AnyMinute API (used by Payroll Canada)
ANYMINUTE_BASE_URL=http://localhost:8001

# Payroll integration API key (auto-generated, can be regenerated in Settings)
ANYMINUTE_PAYROLL_KEY=your-payroll-api-key-here

# API request timeout in seconds
ANYMINUTE_TIMEOUT_SECONDS=15

# Use mock data instead of real API (for development)
USE_MOCK=false

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
# Environment: development, staging, production
APP_ENV=development

# Enable debug mode (set to false in production)
DEBUG=true

# Seed demo data on application startup
SEED_ON_STARTUP=true

# Admin notification email
ADMIN_EMAIL=admin@yourdomain.com
