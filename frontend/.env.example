# =============================================================================
# AnyMinute Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# Variables must be prefixed with REACT_APP_ to be accessible in the app
# =============================================================================

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
# Backend API URL (include protocol, no trailing slash)
# Development: http://localhost:8001
# Production: https://api.yourdomain.com
REACT_APP_BACKEND_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# STRIPE INTEGRATION
# -----------------------------------------------------------------------------
# Stripe publishable key (safe to expose in frontend)
# Get from https://dashboard.stripe.com/apikeys
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------
# Enable/disable features during development
# REACT_APP_ENABLE_ANALYTICS=true
# REACT_APP_ENABLE_STRIPE=true

# -----------------------------------------------------------------------------
# BUILD CONFIGURATION
# -----------------------------------------------------------------------------
# WebSocket port for hot reload (development only)
WDS_SOCKET_PORT=443

# Disable health check endpoint
ENABLE_HEALTH_CHECK=false
